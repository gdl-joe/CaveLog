# Abhängigkeiten
frontend/node_modules/

# Build-Quellcode (Entwickler bauen lokal mit npm run build)
# Die fertigen Dateien in public/ sind im Repo enthalten

# Sensible Konfiguration
.env
.env.local
.env.*.local

# Uploads (Nutzerdaten — niemals ins Repo)
uploads/

# SQLite-Datenbankdatei (enthält echte Daten — niemals ins Repo!)
db/*.db
db/*.db-shm
db/*.db-wal

# Temporäre Dateien
.DS_Store
*.log
/tmp/

# PHP-Cache
*.cache
