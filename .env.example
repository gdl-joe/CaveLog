# CaveLog Umgebungsvariablen
# Kopieren als .env und anpassen — NIEMALS ins Git-Repo committen!

# Datenbank
DB_HOST=localhost
DB_NAME=cavelog
DB_USER=root
DB_PASS=

# Mapy.cz API-Key
# Account erstellen auf https://developer.mapy.com
MAPY_API_KEY=

# App
APP_URL=http://localhost/CaveLog
APP_DEBUG=true

# Vite (für Frontend .env)
VITE_MAPY_API_KEY=
